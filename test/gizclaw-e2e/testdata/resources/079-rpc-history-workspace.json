{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ResourceList",
  "metadata": {
    "name": "rpc-history-workspace"
  },
  "spec": {
    "items": [
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workflow",
        "metadata": {
          "description": "History/replay RPC workflow fixture",
          "name": "e2e-rpc-history-workflow"
        },
        "spec": {
          "chatroom": {
            "history": {
              "ttl": "168h"
            }
          },
          "driver": "chatroom"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workspace",
        "metadata": {
          "name": "e2e-rpc-history-workspace"
        },
        "spec": {
          "parameters": {
            "agent_type": "chatroom"
          },
          "workflow_name": "e2e-rpc-history-workflow"
        }
      }
    ]
  }
}
