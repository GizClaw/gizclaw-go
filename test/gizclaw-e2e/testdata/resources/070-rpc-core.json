{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ResourceList",
  "metadata": {
    "name": "rpc-core"
  },
  "spec": {
    "items": [
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "e2e-rpc-credential"
        },
        "spec": {
          "body": {
            "api_key": "sk-e2e-rpc"
          },
          "description": "Schema-valid fake RPC e2e credential",
          "provider": "openai"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Model",
        "metadata": {
          "name": "e2e-rpc-model"
        },
        "spec": {
          "kind": "llm",
          "name": "RPC Fixture e2e-rpc-model",
          "provider": {
            "kind": "openai-tenant",
            "name": "e2e-rpc-provider"
          },
          "provider_data": {
            "support_json_output": true,
            "upstream_model": "e2e-rpc-core-model",
            "use_system_role": true
          },
          "source": "manual"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Voice",
        "metadata": {
          "name": "e2e-rpc-voice"
        },
        "spec": {
          "description": "Manual fake voice row for RPC e2e metadata coverage",
          "name": "RPC Fixture Voice",
          "provider": {
            "kind": "minimax-tenant",
            "name": "e2e-rpc-provider"
          },
          "provider_data": {
            "raw": {
              "origin": "rpc-e2e-fixture"
            },
            "voice_id": "e2e-rpc-voice-id",
            "voice_type": "voice_cloning"
          },
          "source": "manual"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workflow",
        "metadata": {
          "description": "Stable RPC workflow fixture",
          "name": "e2e-rpc-workflow"
        },
        "spec": {
          "driver": "flowcraft",
          "flowcraft": {
            "entry_agent": ""
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workflow",
        "metadata": {
          "description": "Run-control RPC workflow fixture",
          "name": "e2e-rpc-run-workflow"
        },
        "spec": {
          "chatroom": {
            "history": {
              "ttl": "168h"
            }
          },
          "driver": "chatroom"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workspace",
        "metadata": {
          "name": "e2e-rpc-workspace"
        },
        "spec": {
          "parameters": {
            "agent_type": "flowcraft",
            "input": "push-to-talk"
          },
          "workflow_name": "e2e-rpc-workflow"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Workspace",
        "metadata": {
          "name": "e2e-rpc-run-workspace"
        },
        "spec": {
          "parameters": {
            "agent_type": "chatroom"
          },
          "workflow_name": "e2e-rpc-run-workflow"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Firmware",
        "metadata": {
          "name": "e2e-rpc-firmware"
        },
        "spec": {
          "description": "RPC e2e firmware fixture",
          "slots": {
            "beta": {
              "version": "9.9.0-beta"
            },
            "develop": {
              "version": "9.9.0-dev"
            },
            "stable": {
              "artifacts": [
                {
                  "kind": "app",
                  "name": "main"
                }
              ],
              "version": "9.9.0"
            }
          }
        }
      }
    ]
  }
}
