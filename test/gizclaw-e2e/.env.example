# Copy this file to test/gizclaw-e2e/.env before running local e2e setup.
# The local .env file must stay uncommitted.
#
# This file is only for the shared e2e config home, context names, and provider
# credentials that cannot be committed as fixture values.
#
# Do not add per-role CONFIG_HOME, transport, UI URL, live/manual selector, or
# artifact path variables here. E2E uses one config home that contains multiple
# fixed contexts. Transport comes from each context config.
#
# CONFIG_HOME points at the shared committed config home. CONTEXT variables
# select identities inside that same config home.
#
# Fill credential groups together. If a group is incomplete, setup scripts skip
# the real-provider fixtures that depend on that group.

# ---------------------------------------------------------------------------
# Shared e2e config home and contexts
# ---------------------------------------------------------------------------

# Shared config home containing every committed e2e context. Leave empty to use
# test/gizclaw-e2e/testdata/config-home.
GIZCLAW_E2E_CONFIG_HOME=

# Setup admin context used by reset/setup scripts to apply resources.
GIZCLAW_E2E_ADMIN_SETUP_CONTEXT=e2e-admin

# Fixed admin test context used by admin API/client e2e tests.
GIZCLAW_E2E_ADMIN_TEST_CONTEXT=e2e-admin-test

# Admin UI context.
GIZCLAW_E2E_ADMIN_UI_CONTEXT=e2e-admin

# Client context used by ordinary client/RPC/chat tests and transport parity.
# Use e2e-client for Noise over UDP or e2e-client-webrtc for WebRTC.
GIZCLAW_E2E_CLIENT_CONTEXT=e2e-client

# Social role A context.
GIZCLAW_E2E_SOCIAL_PERSON_A_CONTEXT=e2e-social-a

# Social role B context.
GIZCLAW_E2E_SOCIAL_PERSON_B_CONTEXT=e2e-social-b

# Play UI context.
GIZCLAW_E2E_PLAY_UI_CONTEXT=e2e-client

# ---------------------------------------------------------------------------
# Doubao Speech credential group
# ---------------------------------------------------------------------------

# Doubao Speech application id used by realtime speech and social voice fixtures.
GIZCLAW_E2E_DOUBAO_APP_ID=

# Doubao Speech API key paired with GIZCLAW_E2E_DOUBAO_APP_ID.
GIZCLAW_E2E_DOUBAO_API_KEY=

# Optional Doubao search API key used by fixtures that enable Doubao search.
GIZCLAW_E2E_DOUBAO_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Volc OpenAPI credential group
# ---------------------------------------------------------------------------

# Volc OpenAPI access key id used by tenant voice sync coverage.
GIZCLAW_E2E_VOLC_OPENAPI_ACCESS_KEY_ID=

# Volc OpenAPI secret access key used by tenant voice sync coverage.
GIZCLAW_E2E_VOLC_OPENAPI_ACCESS_KEY=

# ---------------------------------------------------------------------------
# OpenAI-compatible credential group
# ---------------------------------------------------------------------------

# Optional OpenAI-compatible API key used when applying OpenAI provider fixtures.
GIZCLAW_E2E_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# MiniMax China credential group
# ---------------------------------------------------------------------------

# MiniMax China API key used when applying MiniMax CN credential fixtures.
GIZCLAW_E2E_MINIMAX_CN_API_KEY=

# MiniMax China application id used when applying MiniMax CN tenant fixtures.
GIZCLAW_E2E_MINIMAX_CN_APP_ID=

# MiniMax China group id used when applying MiniMax CN tenant fixtures.
GIZCLAW_E2E_MINIMAX_CN_GROUP_ID=

# Optional MiniMax China voice base URL override for local or proxy testing.
GIZCLAW_E2E_MINIMAX_CN_VOICE_BASE_URL=

# ---------------------------------------------------------------------------
# MiniMax Global credential group
# ---------------------------------------------------------------------------

# MiniMax Global API key used when applying MiniMax Global credential fixtures.
GIZCLAW_E2E_MINIMAX_GLOBAL_API_KEY=

# MiniMax Global application id used when applying MiniMax Global tenant fixtures.
GIZCLAW_E2E_MINIMAX_GLOBAL_APP_ID=

# MiniMax Global group id used when applying MiniMax Global tenant fixtures.
GIZCLAW_E2E_MINIMAX_GLOBAL_GROUP_ID=

# Optional MiniMax Global voice base URL override for local or proxy testing.
GIZCLAW_E2E_MINIMAX_GLOBAL_VOICE_BASE_URL=

# ---------------------------------------------------------------------------
# Gemini / DashScope credential groups
# ---------------------------------------------------------------------------

# Optional Gemini API key used when applying Gemini provider fixtures.
GIZCLAW_E2E_GEMINI_API_KEY=

# Optional DashScope API key used for Qwen/Tongyi-compatible provider fixtures.
GIZCLAW_E2E_DASHSCOPE_API_KEY=
