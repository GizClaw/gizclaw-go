{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ACLPolicyBinding",
  "metadata": {
    "name": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}-credential-openai"
  },
  "spec": {
    "subject": {
      "kind": "pk",
      "id": "${GIZCLAW_E2E_CLIENT_PUBLIC_KEY}"
    },
    "resource": {
      "kind": "credential",
      "id": "${GIZCLAW_E2E_OPENAI_CREDENTIAL:-e2e-openai-credential}"
    },
    "role": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}"
  }
}
