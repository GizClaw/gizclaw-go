  "kind": "ACLPolicyBinding",
  "metadata": {
    "name": "view-${GIZCLAW_E2E_ACL_VIEW:-e2e-client}-voice-story-wukong"
  },
  "spec": {
    "subject": {
      "kind": "view",
      "id": "${GIZCLAW_E2E_ACL_VIEW:-e2e-client}"
    },
    "resource": {
      "kind": "voice",
      "id": "volc-tenant:${GIZCLAW_E2E_VOLC_TENANT:-e2e-volc-tenant}:${GIZCLAW_E2E_STORY_WUKONG_VOICE_ID:-zh_male_sunwukong_mars_bigtts}"
    },
    "role": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}"
  }
}
