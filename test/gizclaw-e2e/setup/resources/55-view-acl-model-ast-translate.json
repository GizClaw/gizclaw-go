{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ACLPolicyBinding",
  "metadata": {
    "name": "view-${GIZCLAW_E2E_ACL_VIEW:-e2e-client}-model-ast-translate"
  },
  "spec": {
    "subject": {
      "kind": "view",
      "id": "${GIZCLAW_E2E_ACL_VIEW:-e2e-client}"
    },
    "resource": {
      "kind": "model",
      "id": "${GIZCLAW_E2E_AST_TRANSLATE_MODEL:-e2e-ast-translate}"
    },
    "role": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}"
  }
}
