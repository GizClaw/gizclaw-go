{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ACLPolicyBinding",
  "metadata": {
    "name": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}-model-chat"
  },
  "spec": {
    "subject": {
      "kind": "pk",
      "id": "${GIZCLAW_E2E_CLIENT_PUBLIC_KEY}"
    },
    "resource": {
      "kind": "model",
      "id": "${GIZCLAW_E2E_CHAT_MODEL:-e2e-chat}"
    },
    "role": "${GIZCLAW_E2E_CLIENT_ROLE:-e2e-client}"
  }
}
