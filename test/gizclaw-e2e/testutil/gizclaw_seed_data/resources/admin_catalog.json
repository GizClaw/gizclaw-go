{
  "apiVersion": "gizclaw.admin/v1alpha1",
  "kind": "ResourceList",
  "metadata": {
    "name": "ui-real-service-catalog"
  },
  "spec": {
    "items": [
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "ui-seed-credential"
        },
        "spec": {
          "provider": "minimax",
          "method": "api_key",
          "description": "Seeded credential for UI real-service tests",
          "body": {
            "api_key": "sk-ui-seed"
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "ui-seed-openai-credential"
        },
        "spec": {
          "provider": "openai",
          "method": "api_key",
          "description": "Seeded OpenAI-compatible credential for UI tests",
          "body": {
            "api_key": "sk-ui-openai-seed"
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "ui-seed-gemini-credential"
        },
        "spec": {
          "provider": "gemini",
          "method": "api_key",
          "description": "Seeded Gemini credential for UI tests",
          "body": {
            "api_key": "sk-ui-gemini-seed"
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "ui-seed-dashscope-credential"
        },
        "spec": {
          "provider": "dashscope",
          "method": "api_key",
          "description": "Seeded DashScope credential for UI tests",
          "body": {
            "api_key": "sk-ui-dashscope-seed"
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Credential",
        "metadata": {
          "name": "ui-seed-volc-credential"
        },
        "spec": {
          "provider": "volc",
          "method": "api_key",
          "description": "Seeded Volcengine credential for UI CLI tests",
          "body": {}
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "OpenAITenant",
        "metadata": {
          "name": "ui-seed-openai-tenant"
        },
        "spec": {
          "kind": "compatible",
          "credential_name": "ui-seed-openai-credential",
          "base_url": "https://api.example.invalid/v1",
          "api_mode": "chat_completions",
          "description": "Seeded OpenAI-compatible tenant for UI tests"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "GeminiTenant",
        "metadata": {
          "name": "ui-seed-gemini-tenant"
        },
        "spec": {
          "credential_name": "ui-seed-gemini-credential",
          "project_id": "ui-seed-project",
          "location": "global",
          "description": "Seeded Gemini tenant for UI tests"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "DashScopeTenant",
        "metadata": {
          "name": "ui-seed-dashscope-tenant"
        },
        "spec": {
          "credential_name": "ui-seed-dashscope-credential",
          "base_url": "https://dashscope.example.invalid/compatible-mode/v1",
          "description": "Seeded DashScope tenant for UI tests"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "MiniMaxTenant",
        "metadata": {
          "name": "ui-seed-tenant"
        },
        "spec": {
          "app_id": "ui-seed-app",
          "group_id": "ui-seed-group",
          "credential_name": "ui-seed-credential",
          "base_url": "https://example.invalid",
          "description": "Seeded MiniMax tenant for UI real-service tests"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "VolcTenant",
        "metadata": {
          "name": "ui-seed-volc-tenant"
        },
        "spec": {
          "app_id": "ui-seed-volc-app",
          "credential_name": "ui-seed-volc-credential",
          "region": "cn-beijing",
          "resource_ids": [
            "seed-tts-2.0"
          ],
          "description": "Seeded Volcengine tenant for UI CLI tests"
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Firmware",
        "metadata": {
          "name": "ui-seed-devkit"
        },
        "spec": {
          "description": "Seeded firmware for UI tests",
          "slots": {
            "rollback": {
              "version": "0.9.0"
            },
            "stable": {
              "version": "1.0.0",
              "artifacts": [
                {
                  "name": "main",
                  "kind": "app",
                  "url": "https://firmware.example/ui-seed-devkit/1.0.0/app.bin"
                }
              ]
            },
            "beta": {
              "version": "1.1.0"
            },
            "develop": {
              "version": "1.2.0"
            },
            "pending": {
              "version": "1.3.0",
              "artifacts": [
                {
                  "name": "assets",
                  "kind": "data",
                  "url": "https://firmware.example/ui-seed-devkit/1.3.0/assets.bin"
                }
              ]
            }
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Voice",
        "metadata": {
          "name": "ui-seed-voice"
        },
        "spec": {
          "source": "manual",
          "provider": {
            "kind": "minimax-tenant",
            "name": "ui-seed-tenant"
          },
          "name": "Seeded UI Voice",
          "description": "Seeded voice for UI real-service tests",
          "provider_data": {
            "minimax-tenant": {
              "voice_id": "provider-ui-seed-voice",
              "voice_type": "voice_cloning",
              "raw": {
                "origin": "integration-seed"
              }
            }
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Voice",
        "metadata": {
          "name": "volc-tenant:ui-seed-volc-tenant:ICL_ui_seed_voice"
        },
        "spec": {
          "source": "manual",
          "provider": {
            "kind": "volc-tenant",
            "name": "ui-seed-volc-tenant"
          },
          "name": "Seeded Volc UI Voice",
          "description": "Seeded Volc voice for UI CLI tests",
          "provider_data": {
            "volc-tenant": {
              "app_id": "ui-seed-volc-app",
              "resource_id": "seed-tts-2.0",
              "state": "Success",
              "status": "Available",
              "voice_id": "ICL_ui_seed_voice",
              "raw": {
                "origin": "integration-seed"
              }
            }
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "Model",
        "metadata": {
          "name": "ui-seed-openai-chat"
        },
        "spec": {
          "kind": "llm",
          "source": "manual",
          "provider": {
            "kind": "openai-tenant",
            "name": "ui-seed-openai-tenant"
          },
          "name": "Seeded OpenAI Chat",
          "description": "Seeded OpenAI-compatible model for UI tests",
          "capabilities": {
            "json_output": true,
            "tool_calls": true,
            "text_only": true,
            "system_role": true,
            "temperature": true
          },
          "provider_data": {
            "openai-tenant": {
              "upstream_model": "gpt-4o-mini"
            }
          }
        }
      },
      {
        "apiVersion": "gizclaw.admin/v1alpha1",
        "kind": "ACLView",
        "metadata": {
          "name": "under-12"
        },
        "spec": {
          "description": "Seeded child-safe content view for UI tests"
        }
      }
    ]
  }
}
