{
  "openapi": "3.0.3",
  "info": {
    "title": "Gear API",
    "description": "Endpoints for the current connected gear.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Self",
      "description": "Current gear operations"
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "operationId": "getInfo",
        "summary": "Get device info",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Device info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/DeviceInfo"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "putInfo",
        "summary": "Update device info",
        "tags": [
          "Public"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./types.json#/components/schemas/DeviceInfo"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated device info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/DeviceInfo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid device info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/registration": {
      "get": {
        "operationId": "getRegistration",
        "summary": "Get gear registration",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Registration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/Registration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/runtime": {
      "get": {
        "operationId": "getRuntime",
        "summary": "Get runtime status",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Runtime status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/Runtime"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/config": {
      "get": {
        "operationId": "getConfig",
        "summary": "Get configuration",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "Configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/Configuration"
                }
              }
            }
          },
          "404": {
            "description": "Gear not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ota": {
      "get": {
        "operationId": "getOTA",
        "summary": "Get OTA summary",
        "tags": [
          "Public"
        ],
        "responses": {
          "200": {
            "description": "OTA summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/OTASummary"
                }
              }
            }
          },
          "404": {
            "description": "OTA not available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/download/firmware/{path}": {
      "get": {
        "operationId": "downloadFirmware",
        "summary": "Download a firmware file",
        "tags": [
          "Public"
        ],
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "description": "Percent-encoded firmware file path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Firmware file",
            "headers": {
              "X-Checksum-SHA256": {
                "schema": {
                  "type": "string"
                }
              },
              "X-Checksum-MD5": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid params",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Firmware file not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
