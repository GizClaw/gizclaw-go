{
  "openapi": "3.0.3",
  "info": {
    "title": "Shared API Types",
    "description": "Shared schemas used across GizClaw OpenAPI services.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "Configuration": {
        "type": "object",
        "properties": {
          "certifications": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearCertification"
            }
          },
          "firmware": {
            "$ref": "#/components/schemas/FirmwareConfig"
          }
        }
      },
      "DepotFile": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "md5"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          }
        }
      },
      "DeviceInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sn": {
            "type": "string"
          },
          "hardware": {
            "$ref": "#/components/schemas/HardwareInfo"
          }
        }
      },
      "ErrorPayload": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorPayload"
          }
        }
      },
      "FirmwareConfig": {
        "type": "object",
        "properties": {
          "channel": {
            "$ref": "#/components/schemas/GearFirmwareChannel"
          }
        }
      },
      "Gear": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "device",
          "configuration",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceInfo"
          },
          "configuration": {
            "$ref": "#/components/schemas/Configuration"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GearCertification": {
        "type": "object",
        "required": [
          "type",
          "authority",
          "id"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/GearCertificationType"
          },
          "authority": {
            "$ref": "#/components/schemas/GearCertificationAuthority"
          },
          "id": {
            "type": "string"
          },
          "authority_name": {
            "type": "string"
          }
        }
      },
      "GearCertificationAuthority": {
        "type": "string",
        "enum": [
          "unknown",
          "ccc",
          "ce",
          "fcc",
          "miit",
          "srrc",
          "rohs",
          "internal"
        ]
      },
      "GearCertificationType": {
        "type": "string",
        "enum": [
          "license",
          "certification"
        ]
      },
      "GearFirmwareChannel": {
        "type": "string"
      },
      "GearIMEI": {
        "type": "object",
        "required": [
          "tac",
          "serial"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tac": {
            "type": "string"
          },
          "serial": {
            "type": "string"
          }
        }
      },
      "GearLabel": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "GearRole": {
        "type": "string",
        "enum": [
          "unspecified",
          "admin",
          "peer",
          "device"
        ]
      },
      "GearStatus": {
        "type": "string",
        "enum": [
          "unspecified",
          "active",
          "blocked"
        ]
      },
      "HardwareInfo": {
        "type": "object",
        "properties": {
          "manufacturer": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "hardware_revision": {
            "type": "string"
          },
          "depot": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          },
          "imeis": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearIMEI"
            }
          },
          "labels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GearLabel"
            }
          }
        }
      },
      "OTASummary": {
        "type": "object",
        "required": [
          "depot",
          "channel",
          "firmware_semver",
          "files"
        ],
        "properties": {
          "depot": {
            "type": "string"
          },
          "channel": {
            "type": "string"
          },
          "firmware_semver": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepotFile"
            }
          }
        }
      },
      "Registration": {
        "type": "object",
        "required": [
          "public_key",
          "role",
          "status",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "public_key": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/GearRole"
          },
          "status": {
            "$ref": "#/components/schemas/GearStatus"
          },
          "auto_registered": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Runtime": {
        "type": "object",
        "required": [
          "online",
          "last_seen_at"
        ],
        "properties": {
          "online": {
            "type": "boolean"
          },
          "last_seen_at": {
            "type": "string",
            "format": "date-time"
          },
          "last_addr": {
            "type": "string"
          }
        }
      }
    }
  }
}
