{
  "openapi": "3.0.3",
  "info": {
    "title": "Peripheral Host API",
    "description": "Device-hosted API consumed over the reverse device channel.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "tags": [
    {
      "name": "Peripheral",
      "description": "Device-side host endpoints"
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "operationId": "getInfo",
        "summary": "Get basic device information",
        "tags": [
          "Peripheral"
        ],
        "responses": {
          "200": {
            "description": "Basic device information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/RefreshInfo"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error"
          }
        }
      }
    },
    "/identifiers": {
      "get": {
        "operationId": "getIdentifiers",
        "summary": "Get device identifiers",
        "tags": [
          "Peripheral"
        ],
        "responses": {
          "200": {
            "description": "Device identifiers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./types.json#/components/schemas/RefreshIdentifiers"
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error"
          }
        }
      }
    }
  }
}
