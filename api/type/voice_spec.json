{
  "openapi": "3.0.3",
  "info": {
    "title": "Voice Spec Type",
    "description": "VoiceSpec schema.",
    "version": "1.0.0"
  },
  "paths": {},
  "components": {
    "schemas": {
      "VoiceSpec": {
        "type": "object",
        "required": [
          "source",
          "provider"
        ],
        "properties": {
          "source": {
            "$ref": "./voice_source.json#/components/schemas/VoiceSource"
          },
          "provider": {
            "$ref": "./voice_provider.json#/components/schemas/VoiceProvider"
          },
          "name": {
            "type": "string",
            "example": "calm narrator"
          },
          "description": {
            "type": "string",
            "example": "calm female narrator"
          },
          "provider_data": {
            "type": "object",
            "description": "Provider-specific debug data keyed by provider kind.",
            "additionalProperties": true,
            "example": {
              "minimax-tenant": {
                "voice_id": "Arabic_CalmWoman",
                "voice_type": "system"
              }
            }
          }
        }
      }
    }
  }
}
